<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="viewModel"
            type="com.acs.quick.sample.login.LoginViewModel" />
    </data>

    <!--
        w600dp 大屏 / 折叠屏展开态 登录页
        ═══════════════════════════════════════════
        左右分栏：左品牌区 45% / 右表单区 55%
        （略宽于 50:50，表单区更宽松，避免 312dp 极端窄屏）
        右面板表单 maxWidth=400dp 水平居中，防止超大屏拉得太宽。
    -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        tools:context=".login.LoginActivity">

        <!-- ══════════════════════════════════════════
             铰链 Guidelines（LoginActivity 动态调整）
             ══════════════════════════════════════════ -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_hinge_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_hinge_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <!-- ══════════════════════════════════════════
             左面板：品牌区 (parent_start … hinge_start)
             ══════════════════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_brand_panel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_hinge_start"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/view_brand_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/quick_bg_login_header"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 品牌内容垂直居中 -->
            <LinearLayout
                android:id="@+id/layout_brand_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/quick_Sp7_24"
                app:layout_constraintBottom_toTopOf="@id/tv_brand_copyright"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:layout_constraintVertical_bias="0.45">

                <!-- Logo -->
                <FrameLayout
                    android:layout_width="@dimen/quick_Sp15_56"
                    android:layout_height="@dimen/quick_Sp15_56"
                    android:background="@drawable/quick_shape_logo_circle_shadow">

                    <ImageView
                        android:id="@+id/iv_logo"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/login_app_name"
                        android:src="@drawable/quick_ic_login_logo"
                        app:tint="@color/quick_S5_247BFF" />
                </FrameLayout>

                <!-- 应用名称 -->
                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp4_12"
                    android:text="@string/login_app_name"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/quick_T2_24"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:gravity="center"
                    android:maxLines="1" />

                <!-- 副标题 -->
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/login_subtitle"
                    android:textColor="@color/quick_white_70alpha"
                    android:textSize="@dimen/quick_T6_12"
                    android:letterSpacing="0.08"
                    android:gravity="center"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- 底部版权 -->
            <TextView
                android:id="@+id/tv_brand_copyright"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/quick_Sp5_16"
                android:text="@string/login_brand_copyright"
                android:textColor="@color/quick_white_50alpha"
                android:textSize="@dimen/quick_T6_12"
                android:letterSpacing="0.05"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════════════════════════════════════
             右面板：表单区 (hinge_end … parent_end)
             表单 maxWidth=400dp 水平居中，
             垂直 chain packed + bias=0.45 稍偏上，给底部注册入口留空间。
             ══════════════════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_form_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingHorizontal="@dimen/quick_Sp8_28"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/guideline_hinge_end"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 表单卡片：maxWidth=400dp 水平居中 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_form"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintWidth_max="@dimen/quick_Sp80_400"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.45"
                app:layout_constraintVertical_chainStyle="packed">

                <!-- 欢迎语 -->
                <TextView
                    android:id="@+id/tv_form_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/login_welcome_back"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="@dimen/quick_T2_24"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- 表单说明 -->
                <TextView
                    android:id="@+id/tv_form_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/login_form_subtitle"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/quick_T5_14"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_form_title" />

                <!-- 手机号 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_phone"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp5_16"
                    android:hint="@string/login_phone_hint"
                    app:boxStrokeColor="@color/quick_login_textfield_stroke"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="clear_text"
                    app:endIconTint="?attr/colorOnSurfaceVariant"
                    app:hintTextColor="@color/quick_login_textfield_hint"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_form_subtitle"
                    app:prefixText="@string/login_phone_prefix"
                    app:prefixTextColor="?attr/colorOnSurfaceVariant"
                    app:prefixTextAppearance="?attr/textAppearanceBodyMedium">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLength="11"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/quick_T5_14"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 密码 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp4_12"
                    android:hint="@string/login_password_hint"
                    app:boxStrokeColor="@color/quick_login_textfield_stroke"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="?attr/colorOnSurfaceVariant"
                    app:hintTextColor="@color/quick_login_textfield_hint"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_phone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/quick_T5_14"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 记住密码 + 忘记密码 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_options"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp3_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_password">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_remember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="@{viewModel.rememberMe}"
                        android:text="@string/login_remember_me"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/quick_T5_14"
                        app:buttonTint="?attr/colorPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="@dimen/quick_Sp2_8"
                        android:paddingVertical="@dimen/quick_Sp1_4"
                        android:text="@string/login_forgot_password"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="@dimen/quick_T5_14"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 登录按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/quick_Sp13_48"
                    android:layout_marginTop="@dimen/quick_Sp5_16"
                    android:enabled="@{viewModel.isFormValid}"
                    android:text="@string/login_button"
                    android:textSize="@dimen/quick_T3_18"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    app:cornerRadius="@dimen/quick_Ra4_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_options" />

                <!-- 用户协议 -->
                <LinearLayout
                    android:id="@+id/layout_agreement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp3_10"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/quick_Sp1_4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_login">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_agreement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:checked="@{viewModel.agreedToTerms}"
                        app:buttonTint="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_agreement_prefix"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/quick_T6_12" />

                    <TextView
                        android:id="@+id/tv_user_agreement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/login_user_agreement"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="@dimen/quick_T6_12" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 注册入口：锚定右面板底部 -->
            <LinearLayout
                android:id="@+id/layout_register_entry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/quick_Sp5_16"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_no_account"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/quick_T5_14" />

                <TextView
                    android:id="@+id/tv_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/quick_Sp2_8"
                    android:paddingVertical="@dimen/quick_Sp1_4"
                    android:text="@string/login_register_now"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/quick_T5_14"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
