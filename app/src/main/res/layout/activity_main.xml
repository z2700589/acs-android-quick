<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:background="@color/quick_M8_F0F2F5"
        tools:context=".main.MainActivity">

        <!-- ============================================================
             欢迎信息
             ============================================================ -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/quick_Sp7_24"
            android:layout_marginEnd="@dimen/quick_Sp7_24"
            android:layout_marginTop="@dimen/quick_Sp8_28"
            android:text="@string/main_welcome"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="@dimen/quick_T2_24"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_welcome_sub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/quick_Sp7_24"
            android:layout_marginEnd="@dimen/quick_Sp7_24"
            android:layout_marginTop="@dimen/quick_Sp1_4"
            android:text="@string/main_welcome_sub"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/quick_T5_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

        <!-- ============================================================
             快捷功能卡片（2x2 网格）
             ============================================================ -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_card_mid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_card_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.57" />

        <!-- 招商项目 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_project"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/quick_Sp7_24"
            android:layout_marginEnd="@dimen/quick_Sp2_8"
            android:layout_marginTop="@dimen/quick_Sp7_24"
            android:layout_marginBottom="@dimen/quick_Sp2_8"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/quick_M10_FFFFFF"
            app:cardCornerRadius="@dimen/quick_Ra5_16"
            app:layout_constraintBottom_toTopOf="@id/guideline_card_center"
            app:layout_constraintEnd_toStartOf="@id/guideline_card_mid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_sub">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/quick_shape_logo_circle"
                    android:contentDescription="@string/main_card_project"
                    android:padding="9dp"
                    android:src="@drawable/quick_ic_login_logo"
                    app:tint="@color/quick_S5_247BFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/main_card_project"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/quick_T5_14"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_card_project_sub"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/quick_T7_10" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 客户管理 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_customer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/quick_Sp2_8"
            android:layout_marginEnd="@dimen/quick_Sp7_24"
            android:layout_marginTop="@dimen/quick_Sp7_24"
            android:layout_marginBottom="@dimen/quick_Sp2_8"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/quick_M10_FFFFFF"
            app:cardCornerRadius="@dimen/quick_Ra5_16"
            app:layout_constraintBottom_toTopOf="@id/guideline_card_center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/guideline_card_mid"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_sub">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/quick_shape_logo_circle"
                    android:contentDescription="@string/main_card_customer"
                    android:padding="9dp"
                    android:src="@drawable/quick_ic_login_logo"
                    app:tint="@color/quick_green5_00BF8F" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/main_card_customer"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/quick_T5_14"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_card_customer_sub"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/quick_T7_10" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 数据分析 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_analytics"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/quick_Sp7_24"
            android:layout_marginTop="@dimen/quick_Sp2_8"
            android:layout_marginEnd="@dimen/quick_Sp2_8"
            android:layout_marginBottom="@dimen/quick_Sp7_24"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/quick_M10_FFFFFF"
            app:cardCornerRadius="@dimen/quick_Ra5_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_card_mid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/guideline_card_center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/quick_shape_logo_circle"
                    android:contentDescription="@string/main_card_analytics"
                    android:padding="9dp"
                    android:src="@drawable/quick_ic_login_logo"
                    app:tint="@color/quick_purple5_6B61FF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/main_card_analytics"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/quick_T5_14"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_card_analytics_sub"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/quick_T7_10" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 个人中心 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_profile"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/quick_Sp2_8"
            android:layout_marginStart="@dimen/quick_Sp2_8"
            android:layout_marginEnd="@dimen/quick_Sp7_24"
            android:layout_marginBottom="@dimen/quick_Sp7_24"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/quick_M10_FFFFFF"
            app:cardCornerRadius="@dimen/quick_Ra5_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/guideline_card_mid"
            app:layout_constraintTop_toBottomOf="@id/guideline_card_center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/quick_shape_logo_circle"
                    android:contentDescription="@string/main_card_profile"
                    android:padding="9dp"
                    android:src="@drawable/quick_ic_login_logo"
                    app:tint="@color/quick_orange4_FFAA00" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/quick_Sp2_8"
                    android:text="@string/main_card_profile"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/quick_T5_14"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_card_profile_sub"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/quick_T7_10" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
