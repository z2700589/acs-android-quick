<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="quick_BaseDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="quick_BottomAnimStyle">
        <item name="android:windowEnterAnimation">@anim/quick_slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/quick_slide_out_bottom</item>
    </style>

    <style name="quick_ScaleAnimStyle">
        <item name="android:windowEnterAnimation">@anim/quick_scale_in</item>
        <item name="android:windowExitAnimation">@anim/quick_scale_out</item>
    </style>

    <style name="Animation_Toast">
        <item name="android:windowEnterAnimation">@anim/quick_fade_in</item>
        <item name="android:windowExitAnimation">@anim/quick_fade_out</item>
    </style>
</resources>
